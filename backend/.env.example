# GridWatch Backend Environment Variables
# Copy this file to .env and fill in your values

PORT=8787

# TTC GTFS-Realtime feed URL
# Register at https://transit.land for a free API key
TTC_RT_URL=https://transit.land/api/v2/rest/agencies/ttc/route_geometries

# Ontario 511 API — register at https://511on.ca/developers
ONTARIO_511_API_KEY=your_key_here
ONTARIO_511_API_URL=https://api.511on.ca/v1/events

# Environment Canada — no key required
EC_ALERTS_URL=https://dd.weather.gc.ca/alerts/provinces/on.xml
EC_RADAR_URL=https://dd.weather.gc.ca/radar/PRECIP/RAIN/GTA/
